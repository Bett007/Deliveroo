FLASK_APP=run.py
FLASK_ENV=development
APP_ENV=development
PORT=5001
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
# In development, local SQLite is used by default when this is true.
USE_LOCAL_DB=true
# Optional custom path for local SQLite DB file.
# LOCAL_DATABASE_PATH=./instance/deliveroo_dev.sqlite3
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deliveroo_dev
# Supabase example:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
CLIENT_ORIGIN=http://localhost:5173,https://*.vercel.app
